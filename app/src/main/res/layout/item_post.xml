<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="30dp"
    android:layout_margin="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:backgroundTint="#E4C8DB"
        >

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/tabUserName"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="6dp"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeRounded16"
            android:backgroundTint="#7EBE8D"
            />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ProfilePhoto"
            android:layout_width="35dp"
            android:layout_height="35dp"
            app:layout_constraintStart_toStartOf="@id/tabUserName"
            app:layout_constraintTop_toTopOf="@id/tabUserName"
            app:layout_constraintBottom_toBottomOf="@id/tabUserName"
            android:layout_margin="10dp"
            app:shapeAppearanceOverlay="@style/ShapeCircle"
            />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lblUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="user name"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/ProfilePhoto"
            app:layout_constraintTop_toTopOf="@id/tabUserName"
            app:layout_constraintBottom_toBottomOf="@id/tabUserName"
            android:layout_marginStart="10dp"/>

        <View
            android:id="@+id/dividerHeader"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#9E9E9E"
            app:layout_constraintTop_toBottomOf="@+id/lblUserName" />



        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgMain"
            android:layout_width="0dp"
            android:layout_height="350dp"
            android:layout_margin="6dp"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tabUserName"
            app:shapeAppearanceOverlay="@style/ShapeRounded16"
             />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRestaurant"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:strokeColor="#BBBBBB"
            app:icon="@drawable/location_icon"
            android:text="Restaurant"
            android:textColor="#000000"
            android:layout_marginTop="10dp"
            android:layout_marginStart="10dp"
            app:iconGravity="end"
            app:iconSize="22dp"
            android:backgroundTint="#7EBE8D"
            app:iconTint="#000000"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imgMain"
             />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lblTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="24dp"
            android:text=""
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/imgMain"
            app:layout_constraintTop_toBottomOf="@+id/imgMain" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgDishIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginTop="12dp"
            app:layout_constraintStart_toStartOf="@+id/lblTitle"
            app:layout_constraintTop_toBottomOf="@+id/lblTitle"
            app:srcCompat="@drawable/dish_icon" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lblDish"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="dish name"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBottomOf="@id/imgDishIcon"
            app:layout_constraintStart_toEndOf="@+id/imgDishIcon" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgKmIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginTop="12dp"
            app:layout_constraintStart_toStartOf="@+id/imgDishIcon"
            app:layout_constraintTop_toBottomOf="@+id/imgDishIcon"

            app:srcCompat="@drawable/ils_icon" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lblPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="price"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBottomOf="@id/imgKmIcon"
            app:layout_constraintStart_toEndOf="@+id/imgKmIcon" />

        <Space
            android:id="@+id/space"
            android:layout_width="0dp"
            android:layout_height="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lblPrice" />



        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLike"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:icon="@drawable/like_empty_icon"
            android:padding="0dp"
            app:iconGravity="textStart"
            app:iconTint="#000000"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/imgMain"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="15dp"
             />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnComment"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:icon="@drawable/comment_icon"
            android:padding="0dp"
            app:iconGravity="textStart"
            app:iconTint="#000000"
            app:iconSize="25dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="7dp"
            app:layout_constraintTop_toBottomOf="@id/imgMain"
            app:layout_constraintEnd_toStartOf="@+id/btnLike"
            />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="11dp"
            android:layout_marginEnd="11dp"
            app:cardCornerRadius="50dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="@+id/imgMain"
            app:layout_constraintTop_toTopOf="@+id/imgMain">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="5dp"
                android:paddingHorizontal="12dp"
                android:orientation="horizontal">
            </androidx.appcompat.widget.LinearLayoutCompat>


        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>