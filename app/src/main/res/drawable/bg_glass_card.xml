<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:top="4dp"
        android:left="4dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#15000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#40FFFFFF"
                android:endColor="#10FFFFFF"
                android:angle="135" />
            <stroke android:width="1.5dp" android:color="#60FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item android:top="1.5dp"
        android:left="1.5dp"
        android:right="1.5dp"
        android:bottom="1.5dp">
        <shape android:shape="rectangle">
            <stroke android:width="0.8dp"
                android:color="#A0FFFFFF" />
            <corners android:radius="19dp" />
        </shape>
    </item>

    <item android:top="2.5dp"
        android:left="2.5dp"
        android:right="2.5dp"
        android:bottom="2.5dp">
        <shape android:shape="rectangle">
            <solid android:color="#4DFFFFFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>

</layer-list>